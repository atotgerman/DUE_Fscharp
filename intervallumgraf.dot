graph G {
  layout=neato;
  overlap=false;
  splines=true;
  1 [label="1", style=filled, fillcolor=lightblue, tooltip="[2,7]"];
  2 [label="2", style=filled, fillcolor=lightblue, tooltip="[3,9]"];
  3 [label="3", style=filled, fillcolor=lightblue, tooltip="[6,11]"];
  4 [label="4", style=filled, fillcolor=lightblue, tooltip="[10,13]"];
  1 -- 2;
  1 -- 3;
  2 -- 3;
  3 -- 4;
}
