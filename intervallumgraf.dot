graph G {
  layout=neato;
  overlap=false;
  splines=true;
  1 [label="1", style=filled, fillcolor=lightblue, tooltip="[2,3]"];
  2 [label="2", style=filled, fillcolor=lightblue, tooltip="[4,8]"];
  3 [label="3", style=filled, fillcolor=lightblue, tooltip="[5,7]"];
  4 [label="4", style=filled, fillcolor=lightblue, tooltip="[8,9]"];
  5 [label="5", style=filled, fillcolor=lightblue, tooltip="[1,10]"];
  1 -- 5;
  2 -- 3;
  2 -- 4;
  2 -- 5;
  3 -- 5;
  4 -- 5;
}
