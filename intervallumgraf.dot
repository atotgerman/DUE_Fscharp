graph G {
  layout=neato;
  overlap=false;
  splines=true;
  1 [label="1", style=filled, fillcolor=lightblue, tooltip="[2,7]"];
  2 [label="2", style=filled, fillcolor=lightblue, tooltip="[3,8]"];
  3 [label="3", style=filled, fillcolor=lightblue, tooltip="[7,9]"];
  4 [label="4", style=filled, fillcolor=lightblue, tooltip="[10,11]"];
  5 [label="5", style=filled, fillcolor=lightblue, tooltip="[12,18]"];
  6 [label="6", style=filled, fillcolor=lightblue, tooltip="[13,15]"];
  1 -- 2;
  1 -- 3;
  2 -- 3;
  5 -- 6;
}
